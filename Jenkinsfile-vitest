pipeline {
	agent any

	tools {
		nodejs 'NodeJS'
	}

	options {
		timestamps()
	}

	stages {
		stage('Checkout') {
			steps {
				echo "Checking out source code..."
				checkout scm
			}
		}

		stage('Install Dependencies') {
			steps {
				echo "Installing npm dependencies..."
				sh 'npm install'
			}
		}

		stage('Run Vitest') {
			steps {
				echo "Running vitest unit tests..."
				sh 'npx vitest run'
			}
		}
	}

	post {

		success {
			echo "All vitest tests passed."
		}

		failure {
			echo "Vitest tests failed. Fix defects before merging."
		}

		always {
			echo "Pipeline execution completed."
		}
	}
}
