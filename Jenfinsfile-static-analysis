pipeline {
    agent {
        docker {
            image 'node:20-alpine'
            args '-u root'
        }
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('pmd') {
                    sh '''
                        npm i
                    '''
                }
            }
        }

        stage('Static Analysis') {
            steps {
                dir('pmd') {
                    sh 'npm run lint'
                }
            }
        }

    }

    post {
        success {
            echo 'Static Analysis is complete no errors found!'
        }
        failure {
            echo 'Errors found, please fix it'
        }
    }
}